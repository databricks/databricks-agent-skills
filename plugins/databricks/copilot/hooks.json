{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "bash": "python3 hooks/databricks-context.py",
        "powershell": "python hooks/databricks-context.py"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "matcher": "(?i)bash|shell|terminal",
        "bash": "python3 hooks/databricks-auth-helper.py",
        "powershell": "python hooks/databricks-auth-helper.py"
      }
    ]
  }
}
