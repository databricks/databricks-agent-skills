# The plugins/ tree is the built bundle: a generated copy/transform of the
# editable source (skills/, hooks/, commands/, rules/, assets/) plus the four
# per-target plugin.json. It is regenerated by `python3 scripts/skills.py
# generate` and drift-checked in CI, so it is never hand-edited. Marking it
# generated collapses it in GitHub diffs/reviews and excludes it from language
# stats. Edit the source, never plugins/.
plugins/** linguist-generated=true
